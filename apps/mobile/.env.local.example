# Copy this to .env.local and fill in real values from
# Supabase Dashboard → Project Settings → API.
#
# Expo only exposes env vars prefixed with EXPO_PUBLIC_ to the app at runtime.
# Don't put secrets here — these ship to the device.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY
